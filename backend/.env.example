NODE_ENV=production
PORT=8080
DATABASE_URL=postgres://belahza:replace-me@localhost:5432/belahza
JWT_PUBLIC_KEY_OR_SECRET=replace-with-firebase-auth-public-key-or-jwt-secret
FIELD_ENCRYPTION_KEY_BASE64=replace-with-32-byte-base64-key-from-kms
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace-me"}
ALLOWED_ORIGINS=https://app.belahza.app
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# V8.2 hardening
JWT_EXPIRES_IN=30m
ALLOW_DEV_AUTH=true
ADMIN_USER_IDS=dev-user
FIELD_ENCRYPTION_KEY_ID=primary-v1

# V8.3 deployment/release readiness
OLD_FIELD_ENCRYPTION_KEYS_JSON=[]
PGSSL=false

PHONE_LOOKUP_HMAC_SECRET=replace-with-a-long-random-secret
